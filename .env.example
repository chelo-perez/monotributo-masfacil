# Base de datos (Railway provee esto automáticamente)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Seguridad (generar con: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambia-esto-en-produccion
FERNET_KEY=cambia-esto-en-produccion

# App
ENVIRONMENT=production
APP_BASE_URL=https://monotributo.masfacil.com.ar

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@masfacil.com.ar

# Primer usuario admin (se crea solo en el primer deploy)
ADMIN_EMAIL=admin@masfacil.com.ar
ADMIN_PASSWORD=cambia-esto-antes-de-deployar
